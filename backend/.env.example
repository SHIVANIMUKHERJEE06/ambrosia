# Copy this file to ".env" and fill in the values.
# Never commit your actual .env file to GitHub — it's already in .gitignore.

# ── Required ─────────────────────────────────────────────────────────────────
# Any long random string. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

# ── Highly recommended (single key powers BOTH features below) ────────────────
# Google Gemini API key — free tier, no credit card needed.
# Get yours at: https://aistudio.google.com/app/apikey
#
# Powers two features:
#   1. AI analysis of unrecognized ingredients (Gemini text analysis)
#   2. Photo OCR — reads ingredient lists from label photos (Gemini Vision)
#      This replaces Google Cloud Vision. No separate Cloud project needed.
GEMINI_API_KEY=

# ── Optional server config ────────────────────────────────────────────────────
PORT=4000

# In production, set this to your deployed frontend URL (e.g. Vercel URL)
# to restrict CORS. Leave as * for local development.
FRONTEND_URL=*

# Where the JSON database file is stored.
# On Render free tier, set this to /tmp/ambrosia-db.json
DB_PATH=./data-store/db.json
